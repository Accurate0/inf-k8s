# yaml-language-server: $schema=https://k8s-schemas.anurag.sh/argoproj.io/application_v1alpha1.json
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: @@NAME@@
  namespace: argocd
spec:
  syncPolicy:
    syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true
    automated:
      prune: true
      selfHeal: true
  project: @@LOCATION@@
  sources:
    - chart: k8s-http-routes
      repoURL: oci://ghcr.io/accurate0/charts/k8s-http-routes
      targetRevision: @@CHART_VERSION@@
      helm:
        valuesObject:
          routes:
            - name: @@ROUTE_NAME@@
              gateway:
                name: @@GATEWAY@@
                namespace: envoy-gateway-system
              hostnames:
@@HOSTNAMES@@
              rules:
                - backendRefs:
                    - group: ""
                      kind: Service
                      name: @@NAME@@
                      port: @@SERVICE_PORT@@
                      weight: 1
                  matches:
                    - path:
                        type: PathPrefix
                        value: /
    - repoURL: https://github.com/Accurate0/inf-k8s.git
      name: application
      path: @@DIR@@/manifests
      kustomize: {}
  destination:
    server: https://kubernetes.default.svc
    namespace: @@NAME@@
operation:
  initiatedBy:
    username: github-actions
  sync:
    prune: true
    syncStrategy:
      hook: {}
