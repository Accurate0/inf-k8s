---
source: tests/integration.rs
expression: snapshot
---
response:
  - action_groups:
      - actions:
          - set_commit_status
        ran: true
    dry_run: false
    name: mirror-commit-status
external_requests:
  - method: POST
    path: /api/v1/repos/anurag/k8s/statuses/abc1234567890def
    body:
      context: GHA / build
      description: success
      state: success
      target_url: "https://github.com/Accurate0/inf-k8s/actions/runs/789"
    service: forgejo
  - method: GET
    path: /repos/Accurate0/inf-k8s/actions/runs/789
    service: github
  - method: GET
    path: /repos/Accurate0/inf-k8s/actions/runs/789
    service: github
