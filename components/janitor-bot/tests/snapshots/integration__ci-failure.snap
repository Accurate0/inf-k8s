---
source: tests/integration.rs
expression: snapshot
---
response:
  - actions:
      - ensure_labels_exist
      - create_issue
    dry_run: false
    name: manage-github-workflow
external_requests:
  - method: GET
    path: /api/v1/repos/anurag/k8s/labels
    service: forgejo
  - method: POST
    path: /api/v1/repos/anurag/k8s/labels
    body:
      color: "#d73a4a"
      description: ~
      exclusive: ~
      is_archived: ~
      name: github-ci-failure
    service: forgejo
  - method: POST
    path: /api/v1/repos/anurag/k8s/labels
    body:
      color: "#e4e669"
      description: ~
      exclusive: ~
      is_archived: ~
      name: automated
    service: forgejo
  - method: GET
    path: /api/v1/repos/anurag/k8s/issues?state=open&q=%5BGitHub+CI%5D+anurag%2Fk8s+CI+failed&type=issues
    service: forgejo
  - method: GET
    path: /api/v1/repos/anurag/k8s/labels
    service: forgejo
  - method: POST
    path: /api/v1/repos/anurag/k8s/issues
    body:
      assignee: ~
      assignees: ~
      body: "## Workflow Failed\n\n| Detail | Value |\n|--------|-------|\n| Workflow | **CI** |\n| Result | `failure` |\n| Branch | `main` |\n| Run | [#42 (attempt 1)](https://github.com/anurag/k8s/actions/runs/9001) |\n| Commit | [`abc123d`](https://github.com/anurag/k8s/commit/abc123def456) — fix: broken build |\n| Author | Anurag |\n\n### Logs\n\n```\nStep 1\nBuilding...\ncompilation failed\nDone\n```\n\n<!-- {\"branch\":\"main\",\"commit_sha\":\"abc123def456\",\"conclusion\":\"failure\",\"created_at\":\"2026-01-01T00:00:00Z\",\"html_url\":\"https://github.com/anurag/k8s/actions/runs/9001\",\"logs_url\":\"https://github.com/anurag/k8s/actions/runs/9001/logs\",\"run_id\":9001,\"updated_at\":\"2026-01-01T00:05:00Z\",\"workflow\":\"CI\"} -->\n"
      closed: ~
      due_date: ~
      labels: []
      milestone: ~
      ref: ~
      title: "[GitHub CI] anurag/k8s CI failed"
    service: forgejo
  - method: GET
    path: /repos/anurag/k8s/actions/runs/9001/jobs
    service: github
  - method: GET
    path: /repos/anurag/k8s/actions/jobs/1001/logs
    service: github
  - method: GET
    path: /repos/anurag/k8s/actions/runs/9001/jobs
    service: github
  - method: GET
    path: /repos/anurag/k8s/actions/jobs/1001/logs
    service: github
