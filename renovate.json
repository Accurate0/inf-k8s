{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>anurag/k8s//platform-services/renovate/presets/default"],
  "argocd": {
    "managerFilePatterns": [
      "/system-components/.*\\.application\\.yaml$/",
      "/projects/.*/application\\.yaml$/",
      "/platform-services/.*/application\\.yaml$/"
    ]
  },
  "ignorePaths": ["system-components/redis.application.yaml"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/system-components/.*\\.application\\.yaml$/",
        "/projects/.*/application\\.yaml$/",
        "/platform-services/.*/application\\.yaml$/"
      ],
      "matchStrings": [
        "repoURL:\\s*oci://(?<depName>[^\\s]+)\\s*\\n\\s*targetRevision:\\s*(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/ansible/roles/k3s/vars/main\\.yml$/",
        "/ansible/playbooks/k3s-upgrade\\.yaml$/"
      ],
      "matchStrings": ["k3s_version:\\s*\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "k3s-io/k3s",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(\\+k3s(?<build>\\d+))?$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/system-components/barman-cloud-plugin/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "plugin-barman-cloud/releases/download/(?<currentValue>v[^/]+)/manifest\\.yaml"
      ],
      "depNameTemplate": "cloudnative-pg/plugin-barman-cloud",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/system-components/postgres-cluster/postgres\\.yaml$/"
      ],
      "matchStrings": [
        "imageName:\\s*(?<depName>[^\\s:]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)(-(?<compatibility>.+))?$"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["argocd"],
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/accurate0/charts/k8s-http-routes/k8s-http-routes",
        "ghcr.io/accurate0/charts/k8s-secrets/k8s-secrets",
        "ghcr.io/external-secrets/charts/external-secrets/external-secrets",
        "ghcr.io/dragonflydb/dragonfly-operator/helm/dragonfly-operator/dragonfly-operator",
        "ghcr.io/bjw-s-labs/helm/app-template/app-template",
        "code.forgejo.org/forgejo-helm/forgejo/forgejo"
      ],
      "enabled": false
    },
    {
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["k3s-io/k3s"],
      "groupName": "k3s",
      "commitMessageTopic": "k3s",
      "automerge": false
    },
    {
      "matchDatasources": ["terraform-provider", "terraform-module"],
      "registryUrls": ["https://registry.opentofu.org"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/accurate0/cnpg-postgresql"],
      "labels": ["postgres"],
      "minimumReleaseAge": "0 days"
    },
    {
      "matchDatasources": ["helm"],
      "matchPackageNames": ["kube-prometheus-stack"],
      "schedule": ["* * * * 1"]
    }
  ]
}
