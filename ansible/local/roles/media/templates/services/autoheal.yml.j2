  autoheal:
    image: {{ media_images.autoheal }}
    container_name: autoheal
    restart: unless-stopped
    environment:
      AUTOHEAL_CONTAINER_LABEL: autoheal
      AUTOHEAL_INTERVAL: "10"
      AUTOHEAL_START_PERIOD: "60"
      TZ: "{{ media_timezone }}"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
