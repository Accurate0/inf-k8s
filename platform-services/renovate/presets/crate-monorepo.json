{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Crates that are published from monorepos",
  "packageRules": [
    {
      "matchDatasources": ["crate"],
      "matchPackageNames": [
        "tonic",
        "tonic-build",
        "tonic-health",
        "tonic-reflection"
      ],
      "groupName": "tonic",
      "commitMessageTopic": "tonic",
      "automerge": false
    },
    {
      "matchDatasources": ["crate"],
      "matchPackageNames": ["prost", "prost-types"],
      "groupName": "prost",
      "commitMessageTopic": "prost",
      "automerge": false
    }
  ],
  "extends": [
    "monorepo:axum",
    "monorepo:tokio-prost",
    "monorepo:tokio-tracing",
    "monorepo:tonic",
    "monorepo:aws-sdk-rust",
    "monorepo:opentelemetry-rust",
    "monorepo:opentelemetry-rust-contrib",
    "monorepo:serde"
  ]
}
