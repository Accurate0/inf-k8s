{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared labels applied to Renovate PRs.",
  "labels": ["renovate"],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["renovate/major"]
    },
    {
      "matchUpdateTypes": ["minor"],
      "addLabels": ["renovate/minor"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "addLabels": ["renovate/patch"]
    },
    {
      "matchUpdateTypes": ["digest"],
      "addLabels": ["renovate/digest"]
    },
    {
      "matchUpdateTypes": ["pin"],
      "addLabels": ["renovate/pin"]
    },
    {
      "matchUpdateTypes": ["rollback"],
      "addLabels": ["renovate/rollback"]
    },
    {
      "matchUpdateTypes": ["bump"],
      "addLabels": ["renovate/bump"]
    },
    {
      "matchUpdateTypes": ["lockFileMaintenance"],
      "addLabels": ["renovate/lockfile"]
    }
  ]
}
