# Local dev environment. Source before running: `source .env.local && cargo run`.
# Secrets are intentionally blank — fill them in locally, do not commit real keys.

# Postgres (a local instance, or `kubectl port-forward` to the CNPG cluster).
# Needs the timescaledb extension available for the hypertable migration to apply.
export DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_gateway

# Optional infra. Unset FLIPT_URL falls back to a NoOp provider (every flag = default);
# unset REDIS_URL disables caching; unset OTEL_TRACING_URL logs to stdout only.
export FLIPT_URL=http://localhost:8080
export REDIS_URL=redis://localhost:6379
# export OTEL_TRACING_URL=http://localhost:4318/v1/traces

# Guards /admin/* (key management, usage). Any non-empty value enables admin routes.
export ADMIN_TOKEN=local-dev-admin-token

# Upstream provider credentials. A provider is enabled only when its key is non-empty.
export ANTHROPIC_API_KEY=
export OPENAI_API_KEY=
export OPENROUTER_API_KEY=
export GEMINI_API_KEY=

# Optional overrides (defaults shown).
# export ANTHROPIC_BASE_URL=https://api.anthropic.com
# export OPENAI_BASE_URL=https://api.openai.com/v1
# export OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# export GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# export ANTHROPIC_VERSION=2023-06-01
# export PORT=3000
