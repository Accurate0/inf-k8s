---
source: tests/integration.rs
expression: snapshot
---
response:
  status: 200
  body:
    - message:
        content: []
        id: "[id]"
        model: claude-opus-4-8
        role: assistant
        usage:
          input_tokens: 5
          output_tokens: 0
      type: message_start
    - content_block:
        text: ""
        type: text
      index: 0
      type: content_block_start
    - delta:
        text: Hi there
        type: text_delta
      index: 0
      type: content_block_delta
    - index: 0
      type: content_block_stop
    - delta:
        stop_reason: end_turn
      type: message_delta
      usage:
        output_tokens: 7
    - type: message_stop
upstream_requests:
  - method: POST
    path: /v1/messages
    body:
      max_tokens: 64
      messages:
        - content: hello
          role: user
      model: claude-opus-4-8
      stream: true
