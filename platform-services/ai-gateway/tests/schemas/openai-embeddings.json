{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenAI Embeddings response",
  "type": "object",
  "required": ["object", "model", "data"],
  "properties": {
    "object": { "const": "list" },
    "model": { "type": "string" },
    "data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["object", "index", "embedding"],
        "properties": {
          "object": { "const": "embedding" },
          "index": { "type": "integer" },
          "embedding": {
            "type": "array",
            "items": { "type": "number" }
          }
        }
      }
    }
  }
}
