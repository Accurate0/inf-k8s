{
  "uid": "ai-gateway",
  "title": "AI Gateway",
  "tags": ["ai-gateway"],
  "editable": true,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "current": {},
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(ai_gateway_requests_total[5m]))" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error ratio (5xx)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ai_gateway_requests_total{status=\"5xx\"}[5m])) / clamp_min(sum(rate(ai_gateway_requests_total[5m])), 1e-9)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cost (last 24h)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(increase(ai_gateway_cost_microusd_total[24h])) / 1e6" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Stream truncations (24h)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "sum(increase(ai_gateway_stream_truncated_total[24h]))" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request rate by status",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(ai_gateway_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(ai_gateway_request_duration_seconds{quantile=\"0.5\"})",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "avg(ai_gateway_request_duration_seconds{quantile=\"0.95\"})",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "avg(ai_gateway_request_duration_seconds{quantile=\"0.99\"})",
          "legendFormat": "p99"
        },
        {
          "refId": "D",
          "expr": "sum(rate(ai_gateway_request_duration_seconds_sum[5m])) / clamp_min(sum(rate(ai_gateway_request_duration_seconds_count[5m])), 1e-9)",
          "legendFormat": "avg"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cost rate ($/hour)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model) (rate(ai_gateway_cost_microusd_total[5m])) / 1e6 * 3600",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tokens / sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ai_gateway_input_tokens_total[5m]))",
          "legendFormat": "input"
        },
        {
          "refId": "B",
          "expr": "sum(rate(ai_gateway_output_tokens_total[5m]))",
          "legendFormat": "output"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Upstream errors by provider",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (provider) (rate(ai_gateway_upstream_errors_total[5m]))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request rate by model",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model) (rate(ai_gateway_requests_total[5m]))",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "Spend by key (selected range)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 4 },
        "overrides": []
      },
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "key": "Key", "Value": "USD" } } }
      ],
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "instant": true,
          "expr": "sum by (key) (increase(ai_gateway_cost_microusd_total[$__range])) / 1e6"
        }
      ]
    }
  ]
}
