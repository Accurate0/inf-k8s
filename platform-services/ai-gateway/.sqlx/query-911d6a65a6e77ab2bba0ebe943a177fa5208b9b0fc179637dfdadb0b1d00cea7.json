  "query": "SELECT key_name, resolved_model AS model, date_trunc('day', created_at)::date AS day, SUM(input_tokens)::bigint AS input_tokens, SUM(output_tokens)::bigint AS output_tokens, COUNT(*)::bigint AS requests FROM usage_events WHERE created_at >= now() - interval '30 days' GROUP BY key_name, resolved_model, date_trunc('day', created_at)::date ORDER BY day DESC, key_name, model LIMIT 1000",
