---
source: tests/integration.rs
expression: snapshot
---
response:
  - action_groups:
      - actions:
          - ensure_labels_exist
          - create_issue
        ran: false
        when: is_failure && !is_renovate
      - actions:
          - close_issue
        ran: false
        when: is_success
    dry_run: false
    name: manage-github-workflow
    variables:
      - name: is_failure
        value: "true"
      - name: is_renovate
        value: "true"
      - name: is_success
        value: "false"
external_requests:
  - method: GET
    path: /repos/Accurate0/inf-k8s/actions/runs/9003/jobs
    service: github
  - method: GET
    path: /repos/Accurate0/inf-k8s/actions/jobs/3001/logs
    service: github
  - method: GET
    path: /repos/Accurate0/inf-k8s/actions/runs/9003/jobs
    service: github
  - method: GET
    path: /repos/Accurate0/inf-k8s/actions/jobs/3001/logs
    service: github
