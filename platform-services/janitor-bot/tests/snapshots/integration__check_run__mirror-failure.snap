---
source: tests/integration.rs
expression: snapshot
---
response:
  - actions:
      - action: set_commit_status
        ran: true
    dry_run: false
    name: mirror-commit-status
external_requests:
  - method: POST
    path: /api/v1/repos/anurag/k8s/statuses/def4567890abc123
    body:
      context: GitHub Actions / test
      description: failure
      state: failure
      target_url: "https://github.com/Accurate0/inf-k8s/actions/runs/456"
    service: forgejo
  - method: GET
    path: /repos/Accurate0/inf-k8s/actions/runs/456
    service: github
  - method: GET
    path: /repos/Accurate0/inf-k8s/actions/runs/456
    service: github
