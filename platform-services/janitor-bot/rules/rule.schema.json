{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuleDef",
  "type": "object",
  "properties": {
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ActionGroup"
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/Matcher"
      }
    },
    "depends_on": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string"
      }
    },
    "disabled": {
      "$ref": "#/$defs/Disabled"
    },
    "dry_run": {
      "type": "boolean",
      "default": false
    },
    "name": {
      "type": "string"
    },
    "priority": {
      "type": "integer",
      "format": "int32",
      "default": 0
    },
    "when": {
      "$ref": "#/$defs/Matcher"
    }
  },
  "required": [
    "name",
    "when"
  ],
  "$defs": {
    "ActionDef": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "comment": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": {
              "type": "string",
              "const": "approve"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "delete_branch": {
              "type": "boolean",
              "default": true
            },
            "strategy": {
              "$ref": "#/$defs/MergeStrategy"
            },
            "type": {
              "type": "string",
              "const": "merge"
            }
          },
          "required": [
            "type",
            "strategy"
          ]
        },
        {
          "type": "object",
          "properties": {
            "comment": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "comment"
            }
          },
          "required": [
            "type",
            "comment"
          ]
        },
        {
          "type": "object",
          "properties": {
            "labels": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/LabelSpec"
              }
            },
            "target": {
              "anyOf": [
                {
                  "$ref": "#/$defs/IssueTarget"
                },
                {
                  "type": "null"
                }
              ]
            },
            "type": {
              "type": "string",
              "const": "add_labels"
            }
          },
          "required": [
            "type",
            "labels"
          ]
        },
        {
          "type": "object",
          "properties": {
            "labels": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              }
            },
            "prefixes": {
              "description": "Remove any of the PR's current labels whose name starts with one of\nthese prefixes (e.g. `janitor/` to clear all janitor labels).",
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              }
            },
            "type": {
              "type": "string",
              "const": "remove_labels"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "body": {
              "type": "string"
            },
            "deduplicateByTitle": {
              "type": "boolean",
              "default": false
            },
            "labels": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/LabelSpec"
              }
            },
            "on_duplicate_comment": {
              "type": [
                "string",
                "null"
              ]
            },
            "target": {
              "$ref": "#/$defs/IssueTarget"
            },
            "title": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "create_issue"
            }
          },
          "required": [
            "type",
            "target",
            "title",
            "body"
          ]
        },
        {
          "type": "object",
          "properties": {
            "comment": {
              "type": [
                "string",
                "null"
              ]
            },
            "target": {
              "$ref": "#/$defs/IssueTarget"
            },
            "title": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "close_issue"
            }
          },
          "required": [
            "type",
            "target",
            "title"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "argocd_diff"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "repository": {
              "type": "string"
            },
            "target": {
              "$ref": "#/$defs/RetryWorkflowTargetDef"
            },
            "type": {
              "type": "string",
              "const": "retry_workflow"
            }
          },
          "required": [
            "type",
            "target",
            "repository",
            "id"
          ]
        },
        {
          "type": "object",
          "properties": {
            "context": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "sha": {
              "type": "string"
            },
            "state": {
              "type": "string"
            },
            "target": {
              "$ref": "#/$defs/IssueTarget"
            },
            "target_url": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "set_commit_status"
            }
          },
          "required": [
            "type",
            "target",
            "sha",
            "state",
            "context",
            "description",
            "target_url"
          ]
        },
        {
          "type": "object",
          "properties": {
            "sha": {
              "type": "string"
            },
            "target": {
              "$ref": "#/$defs/IssueTarget"
            },
            "timeout_secs": {
              "type": "integer",
              "format": "uint64",
              "default": 30,
              "minimum": 0
            },
            "type": {
              "type": "string",
              "const": "wait_for_github_sync"
            }
          },
          "required": [
            "type",
            "target",
            "sha"
          ]
        },
        {
          "type": "object",
          "properties": {
            "service": {
              "$ref": "#/$defs/ProxyServiceDef"
            },
            "type": {
              "type": "string",
              "const": "proxy_pass"
            }
          },
          "required": [
            "type",
            "service"
          ]
        },
        {
          "type": "object",
          "properties": {
            "author": {
              "type": "string"
            },
            "comment": {
              "type": [
                "string",
                "null"
              ]
            },
            "criteria": {
              "$ref": "#/$defs/CloseOtherPrsCriteria"
            },
            "delete_branch": {
              "type": "boolean",
              "default": false
            },
            "images_metadata_field": {
              "type": "string",
              "default": "images"
            },
            "match_metadata_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "order_by_metadata_field": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "tag_metadata_field": {
              "type": "string",
              "default": "tag"
            },
            "type": {
              "type": "string",
              "const": "close_other_prs"
            }
          },
          "required": [
            "type",
            "author",
            "criteria",
            "match_metadata_fields"
          ]
        }
      ]
    },
    "ActionGroup": {
      "type": "object",
      "properties": {
        "run": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ActionDef"
          }
        },
        "when": {
          "anyOf": [
            {
              "$ref": "#/$defs/Matcher"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "run"
      ]
    },
    "CloseOtherPrsCriteria": {
      "type": "string",
      "enum": [
        "older",
        "older_published_image"
      ]
    },
    "Combinator": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Matcher"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "all"
          ]
        },
        {
          "type": "object",
          "properties": {
            "any": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Matcher"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "any"
          ]
        },
        {
          "type": "object",
          "properties": {
            "not": {
              "$ref": "#/$defs/Matcher"
            }
          },
          "additionalProperties": false,
          "required": [
            "not"
          ]
        }
      ]
    },
    "Disabled": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        }
      ]
    },
    "EventKind": {
      "type": "string",
      "enum": [
        "pr",
        "workflow",
        "commit_status",
        "check_run",
        "push",
        "sync"
      ]
    },
    "EventSource": {
      "type": "string",
      "enum": [
        "forgejo",
        "github",
        "argocd"
      ]
    },
    "EventSourceSpec": {
      "anyOf": [
        {
          "$ref": "#/$defs/EventSource"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EventSource"
          }
        }
      ]
    },
    "IssueTarget": {
      "type": "object",
      "properties": {
        "owner": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        }
      },
      "required": [
        "owner",
        "repo"
      ]
    },
    "LabelSpec": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "color": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "name",
            "color"
          ]
        }
      ]
    },
    "LeafExprMatcher": {
      "type": "object",
      "properties": {
        "expr": {
          "type": "string"
        }
      },
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "$ref": "#/$defs/EventKind"
            },
            "source": {
              "$ref": "#/$defs/EventSourceSpec"
            },
            "type": {
              "type": "string",
              "const": "event"
            }
          },
          "required": [
            "type",
            "kind",
            "source"
          ]
        },
        {
          "type": "object",
          "properties": {
            "owner": {
              "type": "string"
            },
            "repo": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "app_changed_in_commit"
            }
          },
          "required": [
            "type",
            "owner",
            "repo"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "action"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "author"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "mode": {
              "$ref": "#/$defs/StringMatchMode"
            },
            "type": {
              "type": "string",
              "const": "title_matches"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "has_label"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "has_changed_files"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "patterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "type": {
              "type": "string",
              "const": "changed_files_all_match"
            }
          },
          "required": [
            "type",
            "patterns"
          ]
        },
        {
          "type": "object",
          "properties": {
            "patterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "type": {
              "type": "string",
              "const": "changed_files_any_match"
            }
          },
          "required": [
            "type",
            "patterns"
          ]
        },
        {
          "type": "object",
          "properties": {
            "patterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "type": {
              "type": "string",
              "const": "changed_files_none_match"
            }
          },
          "required": [
            "type",
            "patterns"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "is_open"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "is_merged"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "has_conflicts"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "bot.has_approved"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "marker": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "bot.comment_contains"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "marker",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "context": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "default": {
              "type": "boolean"
            },
            "name": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "feature_flag"
            }
          },
          "required": [
            "type",
            "name",
            "default"
          ]
        },
        {
          "type": "object",
          "properties": {
            "after": {
              "type": "string"
            },
            "before": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "time_of_day"
            },
            "tz": {
              "type": "string"
            },
            "weekdays_only": {
              "type": "boolean",
              "default": false
            }
          },
          "required": [
            "type",
            "tz",
            "after",
            "before"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "workflow_conclusion"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "target_branch"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "repository"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "workflow_run_attempt"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "has_status_checks"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "all_status_checks_passed"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "names": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "state": {
              "$ref": "#/$defs/StatusCheckState"
            },
            "type": {
              "type": "string",
              "const": "status_checks"
            }
          },
          "required": [
            "type",
            "names",
            "state"
          ]
        },
        {
          "type": "object",
          "properties": {
            "match_metadata_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "order_by_metadata_field": {
              "type": [
                "string",
                "null"
              ],
              "default": null
            },
            "type": {
              "type": "string",
              "const": "is_latest_by_metadata"
            }
          },
          "required": [
            "type",
            "match_metadata_fields"
          ]
        },
        {
          "type": "object",
          "properties": {
            "images_metadata_field": {
              "type": "string",
              "default": "images"
            },
            "path_metadata_field": {
              "type": "string",
              "default": "path"
            },
            "tag_metadata_field": {
              "type": "string",
              "default": "tag"
            },
            "type": {
              "type": "string",
              "const": "is_latest_published_image"
            }
          },
          "required": [
            "type"
          ]
        }
      ],
      "required": [
        "expr"
      ]
    },
    "LeafMatcher": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "$ref": "#/$defs/EventKind"
            },
            "source": {
              "$ref": "#/$defs/EventSourceSpec"
            },
            "type": {
              "type": "string",
              "const": "event"
            }
          },
          "required": [
            "type",
            "kind",
            "source"
          ]
        },
        {
          "type": "object",
          "properties": {
            "owner": {
              "type": "string"
            },
            "repo": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "app_changed_in_commit"
            }
          },
          "required": [
            "type",
            "owner",
            "repo"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "action"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "author"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "mode": {
              "$ref": "#/$defs/StringMatchMode"
            },
            "type": {
              "type": "string",
              "const": "title_matches"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "has_label"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "type",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "has_changed_files"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "patterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "type": {
              "type": "string",
              "const": "changed_files_all_match"
            }
          },
          "required": [
            "type",
            "patterns"
          ]
        },
        {
          "type": "object",
          "properties": {
            "patterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "type": {
              "type": "string",
              "const": "changed_files_any_match"
            }
          },
          "required": [
            "type",
            "patterns"
          ]
        },
        {
          "type": "object",
          "properties": {
            "patterns": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "type": {
              "type": "string",
              "const": "changed_files_none_match"
            }
          },
          "required": [
            "type",
            "patterns"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "is_open"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "is_merged"
            }
          },
          "required": [
            "type"
          ]
